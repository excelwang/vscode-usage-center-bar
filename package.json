{
  "name": "usage-center-bar",
  "displayName": "Codex Usage Timeline Bar",
  "description": "Display Codex usage capacity and weekly recovery timeline in the VS Code status bar.",
  "version": "0.2.0",
  "publisher": "huajin-local",
  "license": "MIT",
  "homepage": "https://github.com/excelwang/vscode-usage-center-bar#readme",
  "bugs": {
    "url": "https://github.com/excelwang/vscode-usage-center-bar/issues"
  },
  "qna": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/excelwang/vscode-usage-center-bar.git"
  },
  "keywords": [
    "codex",
    "usage",
    "rate-limit",
    "quota",
    "status-bar",
    "openai"
  ],
  "engines": {
    "vscode": "^1.105.0"
  },
  "galleryBanner": {
    "color": "#0f172a",
    "theme": "dark"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "files": [
    "src/**",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "package.json"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:usageCenterBar.refresh",
    "onCommand:usageCenterBar.showDetails",
    "onCommand:usageCenterBar.openSettings"
  ],
  "main": "./src/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "usageCenterBar.refresh",
        "title": "Usage Center Bar: Refresh"
      },
      {
        "command": "usageCenterBar.showDetails",
        "title": "Usage Center Bar: Show Auth File Usage Details"
      },
      {
        "command": "usageCenterBar.openSettings",
        "title": "Usage Center Bar: Open Settings"
      }
    ],
    "configuration": {
      "title": "Usage Center Bar",
      "properties": {
        "usageCenterBar.baseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8317",
          "description": "Usage API base URL."
        },
        "usageCenterBar.endpoint": {
          "type": "string",
          "default": "/api/codex/usage",
          "description": "Usage API path."
        },
        "usageCenterBar.apiKey": {
          "type": "string",
          "default": "",
          "description": "Bearer API key for usage endpoint. Leave empty if endpoint is public."
        },
        "usageCenterBar.pollIntervalSec": {
          "type": "number",
          "default": 60,
          "minimum": 10,
          "maximum": 3600,
          "description": "Polling interval in seconds."
        },
        "usageCenterBar.requestTimeoutMs": {
          "type": "number",
          "default": 15000,
          "minimum": 1000,
          "maximum": 120000,
          "description": "Usage request timeout in milliseconds."
        },
        "usageCenterBar.usedPercentPath": {
          "type": "string",
          "default": "rate_limit.primary_window.used_percent",
          "description": "JSON path to the used percentage value."
        },
        "usageCenterBar.accountNamePath": {
          "type": "string",
          "default": "",
          "description": "Optional JSON path for account name in usage response, e.g. user.email."
        },
        "usageCenterBar.barLength": {
          "type": "number",
          "default": 10,
          "minimum": 5,
          "maximum": 40,
          "description": "Progress bar segment count."
        },
        "usageCenterBar.title": {
          "type": "string",
          "default": "Usage",
          "description": "Prefix text in status bar."
        },
        "usageCenterBar.priority": {
          "type": "number",
          "default": -1000,
          "description": "Status bar item priority (larger value appears more prominently)."
        }
      }
    }
  },
  "scripts": {
    "lint": "echo 'no lint configured'",
    "check": "node --check src/extension.js",
    "package": "vsce package --no-yarn",
    "verify": "npm run check && npm run package"
  },
  "devDependencies": {
    "@types/vscode": "^1.105.0",
    "@vscode/vsce": "^3.6.2"
  }
}
